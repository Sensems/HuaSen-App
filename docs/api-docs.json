              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadFileResponseDto"
                }
              }
            }
          },
          "400": {
            "description": "参数校验失败\n\n文件为空或格式不支持"
          },
          "401": {
            "description": "未认证，需要 Bearer Token"
          }
        },
        "security": [
          {
            "JWT-auth": []
          }
        ],
        "summary": "上传文件到七牛云（multipart/form-data）并创建媒体记录",
        "tags": [
          "存储"
        ]
      }
    },
