    "/notes": {
      "get": {
        "operationId": "NotesController_list",
        "parameters": [
          {
            "name": "page",
            "required": false,
            "in": "query",
            "description": "页码，从 1 开始",
            "schema": {
              "minimum": 1,
              "default": 1,
              "example": 1,
              "type": "number"
            }
          },
          {
            "name": "size",
            "required": false,
            "in": "query",
            "description": "每页数量",
            "schema": {
              "minimum": 1,
              "maximum": 100,
              "default": 20,
              "example": 20,
              "type": "number"
            }
          },
          {
            "name": "type",
            "required": false,
            "in": "query",
            "description": "笔记类型筛选（draft/published/archived）",
            "schema": {
              "example": "published",
              "type": "string"
            }
          },
          {
            "name": "category",
            "required": false,
            "in": "query",
            "description": "按分类 ID 筛选",
            "schema": {
              "example": "clxyz1234567890abcdef",
              "type": "string"
            }
          },
          {
            "name": "tag",
            "required": false,
            "in": "query",
            "description": "按标签 ID 筛选（命中关联该标签的笔记）",
            "schema": {
              "example": "tag_abc123",
              "type": "string"
            }
          },
          {
            "name": "keyword",
            "required": false,
            "in": "query",
            "description": "关键词模糊搜索（匹配标题或正文）",
            "schema": {
              "example": "花森笔记",
              "type": "string"
            }
          },
          {
            "name": "mediaType",
            "required": false,
            "in": "query",
            "description": "按媒体类型筛选",
            "schema": {
              "example": "IMAGE",
              "type": "string",
              "enum": [
                "IMAGE",
                "VOICE",
                "VIDEO",
                "FILE"
              ]
            }
          },
          {
            "name": "view",
            "required": false,
            "in": "query",
            "description": "列表视图：pinned=仅置顶；recent=按创建时间近→远；不传=默认（置顶优先）",
            "schema": {
              "example": "pinned",
              "type": "string",
              "enum": [
                "pinned",
                "recent"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回分页后的笔记列表，data: { items, total, page, size }",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "security": [
          {
            "JWT-auth": []
          }
        ],
        "summary": "获取笔记列表（分页 + 筛选）",
        "tags": [
          "笔记"
        ]
      }
    },
