          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": [
                  "file"
                ],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "要上传的文件"
                  },
                  "type": {
                    "type": "string",
                    "enum": [
                      "IMAGE",
                      "VOICE",
                      "VIDEO",
                      "FILE"
                    ],
                    "description": "媒体类型（可选，不传则从 MIME 推断）"
                  }
                }
              },
              "examples": {
                "上传图片": {
                  "value": {
                    "type": "IMAGE"
                  },
                  "description": "上传图片文件"
                }
              }
